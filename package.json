{
  "name": "word-ai",
  "version": "1.0.8",
  "description": "Word LLM 智能文字处理插件",
  "main": "src/taskpane/taskpane.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:prod": "webpack --mode production && node scripts/build-manifest.js",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "sideload": "office-addin-dev-settings sideload manifest.xml",
    "unload": "office-addin-dev-settings clear manifest.xml"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.3",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-settings": "^3.0.6",
    "style-loader": "^4.0.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "esrecurse": "^4.3.0",
    "office-addin-dev-certs": "^1.13.2"
  }
}
